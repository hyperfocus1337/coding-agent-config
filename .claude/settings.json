{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "alwaysThinkingEnabled": true,
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "enabledPlugins": {
    "ast-grep@ast-grep-marketplace": true,
    "astral@astral-sh": true,
    "caveman@caveman": true,
    "cloudflare@cloudflare": true,
    "code-refactoring@claude-code-workflows": true,
    "code-review@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "codex@openai-codex": true,
    "commit-commands@claude-plugins-official": false,
    "context7-plugin@context7-marketplace": true,
    "feature-dev@claude-plugins-official": true,
    "glab@gitlab-skills": true,
    "notion-workspace-plugin@notion-plugin-marketplace": true,
    "pyright@claude-code-lsps": true,
    "superpowers@claude-plugins-official": false,
    "terraform-skill@antonbabenko": true,
    "watch@claude-video": true
  },
  "env": {
    "ENABLE_LSP_TOOL": "1"
  },
  "extraKnownMarketplaces": {
    "antonbabenko": {
      "source": {
        "repo": "antonbabenko/agent-plugins",
        "source": "github"
      }
    },
    "ast-grep-marketplace": {
      "source": {
        "repo": "ast-grep/agent-skill",
        "source": "github"
      }
    },
    "astral-sh": {
      "source": {
        "repo": "astral-sh/claude-code-plugins",
        "source": "github"
      }
    },
    "caveman": {
      "source": {
        "repo": "JuliusBrussee/caveman",
        "source": "github"
      }
    },
    "claude-code-lsps": {
      "source": {
        "repo": "piebald-ai/claude-code-lsps",
        "source": "github"
      }
    },
    "claude-code-workflows": {
      "source": {
        "repo": "wshobson/agents",
        "source": "github"
      }
    },
    "claude-plugins-official": {
      "source": {
        "repo": "anthropics/claude-plugins-official",
        "source": "github"
      }
    },
    "claude-video": {
      "source": {
        "repo": "bradautomates/claude-video",
        "source": "github"
      }
    },
    "cloudflare": {
      "source": {
        "repo": "cloudflare/skills",
        "source": "github"
      }
    },
    "context7-marketplace": {
      "source": {
        "repo": "upstash/context7",
        "source": "github"
      }
    },
    "gitlab-skills": {
      "source": {
        "source": "git",
        "url": "https://gitlab.com/gitlab-org/ai/skills.git"
      }
    },
    "notion-plugin-marketplace": {
      "source": {
        "repo": "makenotion/claude-code-notion-plugin",
        "source": "github"
      }
    },
    "openai-codex": {
      "source": {
        "repo": "openai/codex-plugin-cc",
        "source": "github"
      }
    }
  },
  "hooks": {
    "PermissionRequest": [
      {
        "hooks": [
          {
            "command": "bash '/home/node/.claude/hooks/herdr-agent-state.sh' blocked",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "node \"$HOME/.claude/hooks/prettify-md-tables/hook.mjs\"",
            "timeout": 10,
            "type": "command"
          },
          {
            "command": "bash \"$HOME/.claude/hooks/stage-edited-file/hook.sh\"",
            "timeout": 5,
            "type": "command"
          },
          {
            "command": "bash \"$HOME/.claude/hooks/lint-all-languages/hook.sh\"",
            "timeout": 5,
            "type": "command"
          }
        ],
        "matcher": "Write|Edit|MultiEdit"
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "bash '/home/node/.claude/hooks/herdr-agent-state.sh' working",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "command": "bash '/home/node/.claude/hooks/herdr-agent-state.sh' release",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "bash '/home/node/.claude/hooks/herdr-agent-state.sh' idle",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "bash '/home/node/.claude/hooks/herdr-agent-state.sh' idle",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "command": "bash '/home/node/.claude/hooks/herdr-agent-state.sh' working",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ]
  },
  "model": "opus",
  "skipAutoPermissionPrompt": true,
  "skipDangerousModePermissionPrompt": true,
  "statusLine": {
    "command": "npx -y ccstatusline@latest",
    "padding": 0,
    "refreshInterval": 10,
    "type": "command"
  }
} 
